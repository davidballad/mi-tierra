rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isSeller() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "seller";
    }

    // ── /users/{uid} ────────────────────────────────────────────────────────
    // Users can only read and write their own document.
    match /users/{uid} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid)
                    && request.resource.data.keys().hasAll(["uid","email","role","province","createdAt"])
                    && request.resource.data.role in ["buyer","seller"];
      allow update: if isOwner(uid)
                    && request.resource.data.uid == uid;      // uid is immutable
      allow delete: if false;                                  // never allow hard deletes
    }

    // ── /shops/{shopId} ─────────────────────────────────────────────────────
    // Anyone can read shops. Only the owner can write.
    match /shops/{shopId} {
      allow read:   if true;
      allow create: if isSeller()
                    && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.ownerId == request.auth.uid;
      allow delete: if false;
    }

    // ── /products/{productId} ───────────────────────────────────────────────
    // Anyone can read products. Only the shop owner can write.
    match /products/{productId} {
      allow read:   if true;
      allow create: if isSeller()
                    && request.resource.data.keys().hasAll(["shopId","title","price","category","images","stock","provinceOrigin","createdAt"]);
      allow update: if isSignedIn()
                    && get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid;
      allow delete: if isSignedIn()
                    && get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid;
    }

    // ── /orders/{orderId} ───────────────────────────────────────────────────
    // Buyer or the shop's seller can read their order. Buyers can create.
    match /orders/{orderId} {
      allow read:   if isSignedIn()
                    && (resource.data.buyerId == request.auth.uid
                        || get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.buyerId == request.auth.uid
                    && request.resource.data.keys().hasAll([
                         "buyerId","shopId","items","totalPrice","platformFee",
                         "status","paymentMethod","buyerWhatsApp","createdAt"
                       ])
                    && request.resource.data.status == "pending"
                    && request.resource.data.items.size() > 0
                    && request.resource.data.paymentMethod in ["transferencia","contra_entrega"];
      allow update: if false; // Order status updates go through Cloud Functions only
      allow delete: if false;
    }
  }
}
